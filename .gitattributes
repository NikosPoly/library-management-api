# Auto detect text files and perform LF normalization
* text=auto

# Unix shell scripts - always LF
mvnw text eol=lf
*.sh text eol=lf

# Windows scripts - always CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Java source files - LF
*.java text eol=lf

# XML/Config files - LF
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.md text eol=lf

# Binary files - no line ending conversion
*.jar binary
*.class binary
*.png binary
*.jpg binary
